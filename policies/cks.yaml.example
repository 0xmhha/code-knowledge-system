# Example cks runtime configuration.
#
# Copy to ./cks.yaml (gitignored) or to your deployment location, then
# adjust paths. The Validate step at load time rejects unknown keys,
# invalid logging levels, non-loopback HTTP bindings, and unrecognized
# sanitize default actions — so typos surface immediately.

version: 1

backends:
  ckg:
    # Path to the ckg SQLite store (created by `ckg build`). Opened
    # in-process via ckgclient.NewReal — no subprocess on the query path.
    path: "./data/ckg.db"
    # Source tree the index was built against (body fetcher + cks.ops.index --src).
    source_root: "/Users/wm-it-22-00661/Work/github/stable-net/go-stablenet-latest"
    # ckg binary for the cks.ops.index maintenance tool (shells `ckg build`).
    # Empty disables the ckg leg of cks.ops.index.
    binary_path: "ckg"
    # ckg governance policy (the policies/policy.yaml emitted by cks-domain-sync).
    # When set, cks.ops.index passes it to `ckg build --policy-file` so
    # governed_by edges are rebuilt with the index. Empty omits the flag.
    policy_file: "./policies/policy.yaml"
    timeout_ms: 5000
  ckv:
    # Path to the ckv vector store dir (vector.db + manifest.json from
    # `ckv build`). Opened in-process via pkg/ckv (G1) — no `ckv mcp`
    # subprocess. R1' requires a running Ollama daemon for the embedder; if
    # it's unreachable cks falls back to degraded mode (Smart Dummy +
    # cks.ops.health reports "degraded") instead of crashing.
    path: "./ckv-stablenet"
    timeout_ms: 3000
    # Ollama embedding model. Must match the model the index was built with;
    # bge-m3 is multilingual (Korean+English), 1024-dim.
    embed_model: "bge-m3"
    # Ollama daemon endpoint. Empty → http://localhost:11434 (and the
    # CKV_OLLAMA_ENDPOINT env override).
    ollama_url: "http://localhost:11434"
    # ckv binary for the cks.ops.index maintenance tool (shells `ckv reindex`
    # / `ckv build`). Empty disables the ckv leg of cks.ops.index.
    binary_path: "ckv"

listen:
  # HTTP listener for the cks REST surface (loopback only in Phase 0/1).
  http_addr: "127.0.0.1:8080"
  # Whether to also serve the MCP stdio surface (consumed by claude mcp add).
  mcp_stdio: true

logging:
  # debug | info | warn | error
  level: "info"
  # prod (JSON to stdout/file) | dev (console with colors)
  mode: "prod"
  # Footprint logs (high-volume perf/debug events). Cleared via `make log-clear`.
  footprint_dir: "./logs/footprint"
  # Audit logs (tamper-evident; hash-chained — see internal/auditlog).
  audit_dir: "./logs/audit"

sanitize:
  # Path to the sanitization ruleset (regex + action + severity per rule).
  rules_path: "./policies/sanitization_rules.yaml"
  # Fallback redaction action when a rule omits its own action field.
  # mask | drop | fail_closed
  default_action: "drop"
  # If true, the composer refuses to release the pack on any malformed or
  # unrecognized rule action. Defense in depth against ruleset typos that
  # would otherwise bypass redaction.
  fail_closed_on_unknown_rule: true
